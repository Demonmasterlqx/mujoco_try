<mujoco model="double_inverted_pendulum">
    <compiler angle="radian" autolimits="true"/>
    <option timestep="0.001" gravity="0 0 -9.81" integrator="Euler"/>

    <default>
        <joint damping="0.03" armature="0.01"/>
        <geom type="capsule" size="0.025" rgba="0.2 0.4 0.9 1"/>
    </default>

    <worldbody>
        <light name="top_light" pos="0 0 3" dir="0 0 -1"/>
        <geom name="ground" type="plane" size="2 2 0.05" rgba="0.8 0.8 0.8 1"/>
        <body name="link1" pos="0 0 0.15">
            <joint name="joint1" type="hinge" axis="0 1 0" limited="true" range="-1.2 1.2"/>
            <geom name="link1_geom" fromto="0 0 0 0 0 0.45" mass="0.6"/>
            <body name="link2" pos="0 0 0.45">
                <joint name="joint2" type="hinge" axis="0 1 0" limited="true" range="-1.5 1.5"/>
                <geom name="link2_geom" fromto="0 0 0 0 0 0.38" mass="0.35" rgba="0.9 0.4 0.2 1"/>
                <site name="tip" pos="0 0 0.38" size="0.025" rgba="1 0 0 1"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="joint1_motor" joint="joint1" ctrlrange="-25 25" gear="1"/>
        <motor name="joint2_motor" joint="joint2" ctrlrange="-15 15" gear="1"/>
    </actuator>

    <sensor>
        <jointpos name="joint1_position" joint="joint1"/>
        <jointpos name="joint2_position" joint="joint2"/>
        <jointvel name="joint1_velocity" joint="joint1"/>
        <jointvel name="joint2_velocity" joint="joint2"/>
        <actuatorfrc name="joint1_torque" actuator="joint1_motor"/>
        <actuatorfrc name="joint2_torque" actuator="joint2_motor"/>
        <framepos name="tip_position" objtype="site" objname="tip"/>
        <clock name="simulation_clock"/>
    </sensor>

    <keyframe>
        <key name="small_error" qpos="0.12 -0.08" qvel="0 0"/>
    </keyframe>
</mujoco>
